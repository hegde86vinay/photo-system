# Copy to .env and fill in your values
DATABASE_URL=postgresql+asyncpg://photouser:photopass@postgres:5432/photodb
REDIS_URL=redis://redis:6379/0
ES_URL=http://elasticsearch:9200
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
HOT_BUCKET=photos-hot
WARM_BUCKET=photos-warm
COLD_BUCKET=photos-cold
HOT_TO_WARM_DAYS=365
WARM_TO_COLD_DAYS=1095
CACHE_TTL=3600
APP_ENV=development
LOG_LEVEL=INFO
